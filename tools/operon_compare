#!/usr/bin/env bash
# Compare a ref build against an asmjit build on the standard SR benchmark suite.
#
# Usage:
#   operon_compare <ref-root> <new-root> [extra compare_operon.py args...]
#
# Defaults:
#   ref-root  /home/bogdb/src/operon-ref
#   new-root  /home/bogdb/src/operon
#
# The new build is expected to have USE_ASMJIT=ON; --jit is passed automatically.
# Run from the repo root or any directory — the script finds compare_operon.py
# relative to itself.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

REF="${1:-/home/bogdb/src/operon-ref}"
NEW="${2:-/home/bogdb/src/operon}"
shift 2 2>/dev/null || true

exec python3 "$SCRIPT_DIR/compare_operon.py" \
    "$REF" "$NEW" \
    --binaries   operon_nsgp \
    --datasets   Poly-10,Friedman-II \
    --objectives r2 \
    --only-stats \
    --new-jit \
    --population-size 1000 \
    --generations     1000 \
    --stat-seeds      30 \
    --threads         16 \
    --jobs            2 \
    --timeout         600 \
    "$@"
